@startuml Registration_Activity
start
:Guest visits RubyGYM website;
:Click "Register";
:Fill registration form\n(email, password, name, phone);
:Submit form;

:Backend validates input;
if (Email already exists?) then (yes)
  :Return error "Email taken";
  stop
else (no)
  :Hash password with bcrypt;
  :Insert user into database;
  :Create member profile;
  :Select subscription plan\n(Quarterly / Semi-annual / Annual);
  :Choose or get assigned a trainer;
  :Account created successfully;
  :Redirect to login;
  stop
endif
@enduml
